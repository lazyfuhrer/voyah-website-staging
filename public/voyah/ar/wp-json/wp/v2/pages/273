7\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a <a href=\"mailto:crmteam@voyahqatar.com\"><strong>crmteam@voyahqatar.com<\/strong><\/a>.<\/li>\n\n\n\n<li>\u0625\u0630\u0627 \u0627\u062d\u062a\u062c\u0646\u0627 \u0625\u0644\u0649 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0628\u0643\u060c \u0641\u0633\u0646\u0642\u0648\u0645 \u0628\u0630\u0644\u0643 \u0639\u0628\u0631 \u0627\u0644\u0647\u0627\u062a\u0641 \u0623\u0648 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0641\u064a \u0637\u0644\u0628\u0643.<\/li>\n\n\n\n<li>\u0627\u0644\u0625\u0634\u0627\u0631\u0627\u062a \u0625\u0644\u0649 &#8220;\u0627\u0644\u0643\u062a\u0627\u0628\u0629&#8221; \u0623\u0648 &#8220;\u0645\u0643\u062a\u0648\u0628&#8221; \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u062a\u0634\u0645\u0644 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a.<\/li>\n<\/ol>\n\n\n\n<p><strong>5. <\/strong><strong>\u0645\u0631\u0643\u0628\u0627\u062a\u0646\u0627<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u0646\u0633\u0639\u0649 \u062c\u0627\u0647\u062f\u064a\u0646 \u0644\u0639\u0631\u0636 \u0623\u062d\u062c\u0627\u0645 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u0648\u0623\u0644\u0648\u0627\u0646\u0647\u0627 \u0648\u0645\u0644\u062d\u0642\u0627\u062a\u0647\u0627 \u0648\u062a\u062c\u0647\u064a\u0632\u0627\u062a\u0647\u0627 \u0628\u062f\u0642\u0629\u060c \u0648\u0644\u0643\u0646 \u0644\u0627 \u064a\u0645\u0643\u0646\u0646\u0627 \u0636\u0645\u0627\u0646 \u0623\u0646 \u064a\u0639\u0643\u0633 \u062c\u0647\u0627\u0632\u0643 \u0627\u0644\u0623\u0644\u0648\u0627\u0646 \u0623\u0648 \u0627\u0644\u0623\u062d\u062c\u0627\u0645 \u0627\u0644\u0641\u0639\u0644\u064a\u0629 \u0644\u0644\u0645\u0631\u0643\u0628\u0627\u062a.<\/li>\n<\/ol>\n\n\n\n<p><strong>6. <\/strong><strong>\u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0637\u0644\u0628\u060c \u0627\u0644\u0639\u0642\u062f\u060c \u0648\u0627\u062a\u0641\u0627\u0642\u064a\u0627\u062a \u0627\u0644\u062a\u0645\u0648\u064a\u0644<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u0633\u064a\u062a\u0645 \u0625\u0631\u0633\u0627\u0644 \u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0637\u0644\u0628 \u0648\u0627\u0644\u0645\u0633\u062a\u0646\u062f\u0627\u062a \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u0629 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a. \u064a\u0631\u062c\u0649 \u0625\u0643\u0645\u0627\u0644\u0647\u0627 \u0643\u0645\u0627 \u0647\u0648 \u0645\u0648\u0636\u062d \u0644\u062a\u062c\u0646\u0628 \u0623\u064a \u062a\u0623\u062e\u064a\u0631 \u0641\u064a \u0627\u0644\u0645\u0639\u0627\u0644\u062c\u0629.<\/li>\n\n\n\n<li>\u0633\u064a\u062a\u0645 \u062a\u0623\u0643\u064a\u062f \u0627\u0633\u062a\u0644\u0627\u0645 \u0637\u0644\u0628\u0643 \u0627\u0644\u062e\u0627\u0635 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u060c \u0645\u062a\u0636\u0645\u0646\u064b\u0627 \u0631\u0642\u0645 \u0637\u0644\u0628\u0643 \u0627\u0644\u0641\u0631\u064a\u062f.<\/li>\n\n\n\n<li>\u0625\u0630\u0627 \u062f\u062e\u0644\u062a \u0641\u064a \u062a\u0631\u062a\u064a\u0628 \u062a\u0645\u0648\u064a\u0644\u060c \u0641\u0633\u064a\u062e\u0636\u0639 \u0630\u0644\u0643 \u0644\u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0645\u0646\u0641\u0635\u0644\u0629 \u0645\u0639 \u0645\u0632\u0648\u062f \u0627\u0644\u062a\u0645\u0648\u064a\u0644 \u0627\u0644\u0630\u064a \u0627\u062e\u062a\u0631\u062a\u0647.<\/li>\n\n\n\n<li>\u0625\u0630\u0627 \u0644\u0645 \u0646\u062a\u0645\u0643\u0646 \u0645\u0646 \u0642\u0628\u0648\u0644 \u0637\u0644\u0628\u0643 \u0644\u0623\u064a \u0633\u0628\u0628 \u0645\u0646 \u0627\u0644\u0623\u0633\u0628\u0627\u0628\u060c \u0633\u0646\u062e\u0637\u0631\u0643 \u0648\u0644\u0646 \u064a\u062a\u0645 \u062a\u062d\u0635\u064a\u0644 \u0623\u064a \u0631\u0633\u0648\u0645 \u0645\u0646\u0643.<\/li>\n\n\n\n<li>\u062a\u0634\u0645\u0644 \u0623\u0633\u0639\u0627\u0631 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u062a\u0633\u0644\u064a\u0645\u0647\u0627 \u0625\u0644\u0649 \u0645\u0631\u0643\u0632 \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0641\u064a \u0645\u0648\u0627\u062a\u0631. \u062a\u062a\u0648\u0641\u0631 \u062e\u062f\u0645\u0629 \u0627\u0644\u062a\u0648\u0635\u064a\u0644 \u0625\u0644\u0649 \u0627\u0644\u0645\u0646\u0632\u0644 \u0623\u0648 \u0645\u0643\u0627\u0646 \u0627\u0644\u0639\u0645\u0644 \u0645\u0642\u0627\u0628\u0644 \u0631\u0633\u0648\u0645 \u0625\u0636\u0627\u0641\u064a\u0629\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0644\u0634\u0631\u0648\u0637. \u064a\u062c\u0628 \u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0643\u062a\u0627\u0628\u064a\u064b\u0627 \u0639\u0628\u0631 \u0642\u0633\u0645 &#8220;\u0627\u062a\u0635\u0644 \u0628\u0646\u0627&#8221; \u0641\u064a \u0645\u0648\u0642\u0639\u0646\u0627 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0645\u0639 \u0630\u0643\u0631 \u0631\u0642\u0645 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u0641\u0631\u064a\u062f.<\/li>\n<\/ol>\n\n\n\n<p><strong>7. <\/strong><strong>\u0625\u062c\u0631\u0627\u0621 \u062a\u063a\u064a\u064a\u0631\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u0642\u062f \u0646\u0642\u0648\u0645 \u0628\u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u0644\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0644\u0644\u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u062a\u0646\u0638\u064a\u0645\u064a\u0629 \u0623\u0648 \u0625\u062c\u0631\u0627\u0621 \u062a\u062d\u0633\u064a\u0646\u0627\u062a \u0641\u0646\u064a\u0629 \u0637\u0641\u064a\u0641\u0629 (\u0645\u062b\u0644 \u0645\u0639\u0627\u0644\u062c\u0629 \u0645\u062e\u0627\u0648\u0641 \u0627\u0644\u0633\u0644\u0627\u0645\u0629). \u0644\u0646 \u062a\u0624\u062b\u0631 \u0647\u0630\u0647 \u0627\u0644\u062a\u063a\u064a\u064a\u0631\u0627\u062a \u0639\u0644\u0649 \u0642\u0627\u0628\u0644\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0631\u0643\u0628\u0629.<\/li>\n\n\n\n<li>\u0628\u0645\u062c\u0631\u062f \u062a\u0642\u062f\u064a\u0645 \u0637\u0644\u0628 \u062e\u0627\u0635\u060c \u064a\u062a\u0645 \u062a\u0623\u0643\u064a\u062f \u0627\u0644\u0645\u0648\u0627\u0635\u0641\u0627\u062a \u0627\u0644\u0645\u062e\u062a\u0627\u0631\u0629 \u0648\u0644\u0627 \u064a\u0645\u0643\u0646 \u062a\u0639\u062f\u064a\u0644\u0647\u0627 \u0623\u0648 \u062a\u063a\u064a\u064a\u0631\u0647\u0627.<\/li>\n<\/ol>\n\n\n\n<p><strong>8. <\/strong><strong>\u0631\u0633\u0648\u0645 \u0627\u0644\u0637\u0644\u0628 \u0648\u0627\u0644\u0648\u062f\u064a\u0639\u0629<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u062a\u062e\u062a\u0644\u0641 \u0631\u0633\u0648\u0645 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u062e\u0627\u0635 \u0639\u0628\u0631 \u0627\u0644\u0625\u0646\u062a\u0631\u0646\u062a \u062d\u0633\u0628 \u0627\u0644\u0637\u0631\u0627\u0632\/\u0627\u0644\u0645\u0631\u0643\u0628\u0629. \u062a\u062d\u062a\u0641\u0638 \u0634\u0631\u0643\u0629 &#8220;\u0627\u0644\u0648\u0627\u062d\u0629&#8221; \u0628\u0627\u0644\u062d\u0642 \u0641\u064a \u062a\u062d\u062f\u064a\u062f \u0623\u0648 \u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u0631\u0633\u0648\u0645 \u0648\u0641\u0642\u064b\u0627 \u0644\u062a\u0642\u062f\u064a\u0631\u0647\u0627 \u0627\u0644\u062e\u0627\u0635.<\/li>\n\n\n\n<li>\u064a\u062a\u0637\u0644\u0628 \u062f\u0641\u0639 \u0648\u062f\u064a\u0639\u0629 \u063a\u064a\u0631 \u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u0627\u0633\u062a\u0631\u062f\u0627\u062f \u0645\u0646 \u062e\u0644\u0627\u0644 \u0628\u0648\u0627\u0628\u0629 \u0627\u0644\u062f\u0641\u0639. \u062a\u0646\u062a\u0647\u064a \u0635\u0644\u0627\u062d\u064a\u0629 \u0627\u0644\u0648\u062f\u064a\u0639\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u064b\u0627 \u0628\u0639\u062f 48 \u0633\u0627\u0639\u0629 \u0625\u0630\u0627 \u0644\u0645 \u064a\u062a\u0645 \u0627\u0633\u062a\u0644\u0627\u0645 \u0627\u0644\u0623\u0645\u0648\u0627\u0644.<\/li>\n\n\n\n<li>\u0641\u064a \u062d\u0627\u0644 \u0627\u0646\u062a\u0647\u0627\u0621 \u0635\u0644\u0627\u062d\u064a\u0629 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u062e\u0627\u0635\u060c \u064a\u0645\u0643\u0646\u0643 \u062a\u0642\u062f\u064a\u0645 \u0637\u0644\u0628 \u062c\u062f\u064a\u062f \u062a\u062d\u062a \u0646\u0641\u0633 \u0627\u0644\u0634\u0631\u0648\u0637. \u0642\u062f \u064a\u0624\u062f\u064a \u062a\u0643\u0631\u0627\u0631 \u0627\u0644\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0625\u0644\u0649 \u0627\u0644\u0631\u0641\u0636 \u0625\u0630\u0627 \u062a\u0645 \u0627\u0639\u062a\u0628\u0627\u0631 \u0630\u0644\u0643 \u0625\u0633\u0627\u0621\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0644\u0644\u0646\u0638\u0627\u0645.<\/li>\n\n\n\n<li>\u0644\u0627 \u064a\u0645\u0643\u0646\u0643 \u062d\u062c\u0632 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0645\u0631\u0643\u0628\u0629 \u0648\u0627\u062d\u062f\u0629 \u0628\u0627\u0633\u0645\u0643 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0628\u0648\u0627\u0628\u0629. \u064a\u062c\u0628 \u0637\u0644\u0628 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u0627\u0644\u0625\u0636\u0627\u0641\u064a\u0629 \u0645\u0628\u0627\u0634\u0631\u0629\u064b \u0641\u064a \u0635\u0627\u0644\u0627\u062a \u0639\u0631\u0636 Voyah.<\/li>\n<\/ol>\n\n\n\n<p><strong>9. <\/strong><strong>\u062a\u0648\u0641\u064a\u0631 \u0627\u0644\u0645\u0631\u0643\u0628\u0629<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u062a\u0648\u0627\u0631\u064a\u062e \u0648\u0635\u0648\u0644 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u0627\u0644\u0645\u0642\u062f\u0631\u0629 \u0647\u064a \u0645\u062c\u0631\u062f \u062a\u0642\u062f\u064a\u0631\u0627\u062a \u0648\u0644\u0627 \u062a\u0636\u0645\u0646 \u0645\u0648\u0627\u0639\u064a\u062f \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0627\u0644\u0641\u0639\u0644\u064a\u0629. \u0642\u062f \u062a\u062a\u063a\u064a\u0631 \u062a\u0648\u0627\u0631\u064a\u062e \u0627\u0644\u0648\u0635\u0648\u0644 \u0628\u0633\u0628\u0628 \u0638\u0631\u0648\u0641 \u063a\u064a\u0631 \u0645\u062a\u0648\u0642\u0639\u0629. \u0633\u0646\u062a\u062e\u0630 \u062c\u0645\u064a\u0639 \u0627\u0644\u062e\u0637\u0648\u0627\u062a \u0627\u0644\u0645\u0639\u0642\u0648\u0644\u0629 \u0644\u062a\u0642\u0644\u064a\u0644 \u0627\u0644\u062a\u0623\u062e\u064a\u0631 \u0648\u0644\u0643\u0646\u0646\u0627 \u063a\u064a\u0631 \u0645\u0633\u0624\u0648\u0644\u064a\u0646 \u0639\u0646 \u0623\u064a \u0645\u0637\u0627\u0644\u0628\u0627\u062a \u062a\u062a\u0639\u0644\u0642 \u0628\u0627\u0644\u062a\u0623\u062e\u064a\u0631.<\/li>\n\n\n\n<li>\u0633\u0646\u062a\u0635\u0644 \u0628\u0643 \u0644\u062a\u0631\u062a\u064a\u0628 \u062a\u0627\u0631\u064a\u062e \u0648\u0648\u0642\u062a \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u064a\u0646. \u064a\u0631\u062c\u0649 \u0625\u062d\u0636\u0627\u0631 \u0628\u0637\u0627\u0642\u0629 \u0647\u0648\u064a\u062a\u0643 \u0627\u0644\u0642\u0637\u0631\u064a\u0629 \u0644\u0644\u062a\u062d\u0642\u0642 \u0645\u0646 \u0647\u0648\u064a\u062a\u0643. \u0625\u0630\u0627 \u0643\u0646\u062a \u062a\u0641\u0648\u0636 \u0634\u062e\u0635\u064b\u0627 \u0622\u062e\u0631 \u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0645\u0631\u0643\u0628\u062a\u0643\u060c \u0641\u064a\u062c\u0628 \u062a\u0642\u062f\u064a\u0645 \u062e\u0637\u0627\u0628 \u0639\u062f\u0645 \u0645\u0645\u0627\u0646\u0639\u0629.<\/li>\n\n\n\n<li>\u0625\u0630\u0627 \u0644\u0645 \u062a\u0633\u062a\u0644\u0645 \u0645\u0631\u0643\u0628\u062a\u0643 \u0641\u064a \u0627\u0644\u0645\u0648\u0639\u062f \u0627\u0644\u0645\u062d\u062f\u062f\u060c \u0633\u0646\u062d\u0627\u0648\u0644 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0643 \u0644\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u062a\u0639\u0644\u064a\u0645\u0627\u062a \u0623\u062e\u0631\u0649. \u0642\u062f \u064a\u062a\u0645 \u0641\u0631\u0636 \u0631\u0633\u0648\u0645 \u062a\u062e\u0632\u064a\u0646 \u0642\u062f\u0631\u0647\u0627 50 \u0631\u064a\u0627\u0644\u064b\u0627 \u0642\u0637\u0631\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u064a\u0648\u0645. \u0625\u0630\u0627 \u0644\u0645 \u0646\u062a\u0645\u0643\u0646 \u0645\u0646 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u064a\u0643\u060c \u0641\u0642\u062f \u0646\u0644\u063a\u064a \u0627\u0644\u0639\u0642\u062f.<\/li>\n\n\n\n<li>\u0647\u0646\u0627\u0643 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0645\u0639\u064a\u0646\u0629 \u0645\u0637\u0644\u0648\u0628\u0629 \u0644\u0627\u0633\u062a\u0643\u0645\u0627\u0644 \u0639\u0645\u0644\u064a\u0629 \u062a\u0633\u0644\u064a\u0645 \u0627\u0644\u0645\u0631\u0643\u0628\u0629. \u0625\u0630\u0627 \u0644\u0645 \u062a\u0642\u062f\u0645\u0647\u0627 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u060c \u0641\u0646\u062d\u0646 \u063a\u064a\u0631 \u0645\u0633\u0624\u0648\u0644\u064a\u0646 \u0639\u0646 \u0623\u064a \u062a\u0623\u062e\u064a\u0631 \u0641\u064a \u0627\u0644\u062a\u0633\u0644\u064a\u0645.<\/li>\n<\/ol>\n\n\n\n<p><strong>10. <\/strong><strong>\u0627\u0644\u062a\u0623\u062e\u064a\u0631 \u0641\u064a \u0627\u0644\u062a\u0633\u0644\u064a\u0645<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u0642\u062f \u064a\u062a\u0623\u062e\u0631 \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0625\u0630\u0627:\n<ol class=\"wp-block-list\">\n<li>\u0643\u0627\u0646\u062a \u0647\u0646\u0627\u0643 \u0645\u0634\u0627\u0643\u0644 \u0641\u0646\u064a\u0629 \u062a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u062d\u0644.<\/li>\n\n\n\n<li>\u0643\u0627\u0646\u062a \u0647\u0646\u0627\u0643 \u062a\u063a\u064a\u064a\u0631\u0627\u062a \u062a\u0646\u0638\u064a\u0645\u064a\u0629 \u062a\u062a\u0637\u0644\u0628 \u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0645\u0631\u0643\u0628\u0629.<\/li>\n\n\n\n<li>\u062a\u0645\u062a \u0625\u0636\u0627\u0641\u0629 \u062a\u0639\u062f\u064a\u0644\u0627\u062a \u0625\u0644\u0649 \u0627\u0644\u0645\u0631\u0643\u0628\u0629 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0637\u0644\u0628\u0643 \u0623\u0648 \u0643\u0645\u0627 \u0647\u0648 \u0645\u0637\u0644\u0648\u0628 \u0645\u0646 \u0642\u0628\u0644\u0646\u0627.<\/li>\n<\/ol>\n<\/li>\n<\/ol>\n\n\n\n<p><strong>11. <\/strong><strong>\u062d\u0642\u0648\u0642\u0646\u0627 \u0641\u064a \u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u0639\u0642\u062f<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u064a\u062c\u0648\u0632 \u0644\u0646\u0627 \u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u0639\u0642\u062f \u0641\u064a \u0623\u064a \u0648\u0642\u062a \u0639\u0628\u0631 \u0625\u062e\u0637\u0627\u0631 \u0643\u062a\u0627\u0628\u064a \u0625\u0630\u0627:\n<ol class=\"wp-block-list\">\n<li>\u0644\u0645 \u062a\u0642\u0645 \u0628\u0625\u062c\u0631\u0627\u0621 \u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0645\u0637\u0644\u0648\u0628 \u062e\u0644\u0627\u0644 \u062e\u0645\u0633\u0629 (5) \u0623\u064a\u0627\u0645 \u0645\u0646 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642 \u0628\u0639\u062f \u0625\u0634\u0639\u0627\u0631 \u0627\u0644\u062a\u0630\u0643\u064a\u0631.<\/li>\n<\/ol>\n<\/li>\n<\/ol>\n\n\n\n<p><strong>12. <\/strong><strong>\u062d\u0642\u0648\u0642\u0643 \u0641\u064a \u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u0639\u0642\u062f<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u062a\u0639\u062a\u0645\u062f \u062d\u0642\u0648\u0642\u0643 \u0641\u064a \u0625\u064
u0637\u0647.<\/li>\n\n\n\n<li>\u0644\u0627 \u0646\u0642\u0628\u0644 \u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u0645\u0646 \u0627\u0644\u0623\u0641\u0631\u0627\u062f \u0627\u0644\u0630\u064a\u0646 \u0644\u064a\u0633 \u0644\u062f\u064a\u0647\u0645 \u0628\u0637\u0627\u0642\u0629 \u0647\u0648\u064a\u0629 \u0642\u0637\u0631\u064a\u0629 \u0635\u0627\u0644\u062d\u0629 \u0623\u0648 \u0627\u0644\u0630\u064a\u0646 \u062a\u0642\u0644 \u0623\u0639\u0645\u0627\u0631\u0647\u0645 \u0639\u0646 18 \u0639\u0627\u0645\u064b\u0627.<\/li>\n\n\n\n<li>\u0633\u062a\u0642\u0648\u0645 \u0634\u0631\u0643\u0629 &#8220;\u0627\u0644\u0648\u0627\u062d\u0629 \u0644\u0644\u0633\u064a\u0627\u0631\u0627\u062a&#8221; \u0628\u0625\u0628\u0644\u0627\u063a\u0643 \u0639\u0646\u062f \u0648\u0635\u0648\u0644 \u0645\u0631\u0643\u0628\u062a\u0643. \u0628\u0645\u062c\u0631\u062f \u0625\u062a\u0645\u0627\u0645 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062f\u0641\u0639 \u0648\u0627\u0644\u062a\u0633\u062c\u064a\u0644\u060c \u0633\u062a\u0643\u0648\u0646 \u0627\u0644\u0645\u0631\u0643\u0628\u0629 \u0645\u062a\u0627\u062d\u0629 \u0644\u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0645\u0646 \u0645\u0631\u0643\u0632 \u0627\u0644\u062a\u0633\u0644\u064a\u0645 \u0644\u062f\u064a\u0646\u0627.<\/li>\n<\/ol>\n\n\n\n<p><strong>3. <\/strong><strong>\u0627\u0644\u0633\u0639\u0631 \u0648\u0627\u0644\u062f\u0641\u0639<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u0633\u064a\u0639\u0631\u0636 \u0627\u0644\u0645\u0648\u0642\u0639 \u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0644\u0644\u0645\u0631\u0643\u0628\u0629 \u0627\u0644\u062a\u064a \u062a\u062e\u062a\u0627\u0631\u0647\u0627\u060c \u0648\u0625\u0630\u0627 \u0642\u0645\u062a \u0628\u0627\u062e\u062a\u064a\u0627\u0631 \u0645\u064a\u0632\u0627\u062a \u0627\u062e\u062a\u064a\u0627\u0631\u064a\u0629\u060c \u0641\u0633\u064a\u062a\u0645 \u0625\u0636\u0627\u0641\u062a\u0647\u0627 \u0625\u0644\u0649 \u0633\u0639\u0631 \u0627\u0644\u0645\u0631\u0643\u0628\u0629.<\/li>\n\n\n\n<li>\u064a\u062c\u0628 \u0623\u0646 \u064a\u062a\u0645 \u0627\u0644\u062f\u0641\u0639 \u0645\u0628\u0627\u0634\u0631\u0629\u064b \u0645\u0646 \u0642\u0650\u0628\u064e\u0644 \u0627\u0644\u0634\u062e\u0635 \u0627\u0644\u0630\u064a \u0633\u064a\u062a\u0645 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u0645\u0631\u0643\u0628\u0629 \u0628\u0627\u0633\u0645\u0647. \u0633\u064a\u062a\u0645 \u0631\u0641\u0636 \u0627\u0644\u062f\u0641\u0639\u0627\u062a \u0645\u0646 \u0623\u0637\u0631\u0627\u0641 \u062b\u0627\u0644\u062b\u0629 \u062a\u0644\u0642\u0627\u0626\u064a\u064b\u0627\u060c \u0645\u0645\u0627 \u064a\u0624\u062f\u064a \u0625\u0644\u0649 \u0625\u0644\u063a\u0627\u0621 \u0627\u0644\u0637\u0644\u0628. \u0625\u0630\u0627 \u0644\u0645 \u064a\u0643\u0646 \u0644\u062f\u064a\u0643 \u0628\u0637\u0627\u0642\u0629 \u0627\u0626\u062a\u0645\u0627\u0646\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0644\u062a\u0631\u062a\u064a\u0628 \u062a\u062d\u0648\u064a\u0644 \u0628\u0646\u0643\u064a.<\/li>\n\n\n\n<li>\u064a\u0645\u0643\u0646 \u0633\u062f\u0627\u062f \u0628\u0627\u0642\u064a \u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u0631\u0643\u0628\u0629 \u0639\u0628\u0631 \u0627\u0644\u062a\u062d\u0648\u064a\u0644 \u0627\u0644\u0628\u0646\u0643\u064a \u0623\u0648 \u0639\u0628\u0631 \u062a\u0631\u062a\u064a\u0628\u0627\u062a \u0627\u0644\u062a\u0645\u0648\u064a\u0644. \u064a\u064f\u0633\u0645\u062d \u0628\u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0646\u0642\u062f\u064a \u0628\u062d\u062f \u0623\u0642\u0635\u0649 49,000 \u0631\u064a\u0627\u0644 \u0642\u0637\u0631\u064a \u0644\u0643\u0644 \u0639\u0645\u0644\u064a\u0629 \u0634\u0631\u0627\u0621.<\/li>\n\n\n\n<li>\u0633\u062a\u0628\u062f\u0623 \u0625\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0628\u064a\u0639 \u0641\u0642\u0637 \u0628\u0639\u062f \u0638\u0647\u0648\u0631 \u0627\u0644\u0623\u0645\u0648\u0627\u0644 \u0641\u064a \u062d\u0633\u0627\u0628\u0646\u0627 \u0627\u0644\u0645\u0635\u0631\u0641\u064a.<\/li>\n\n\n\n<li>\u064a\u062c\u0628 \u0625\u062a\u0645\u0627\u0645 \u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0643\u0627\u0645\u0644 \u062e\u0644\u0627\u0644 \u062e\u0645\u0633\u0629 (5) \u0623\u064a\u0627\u0645 \u0639\u0645\u0644 \u0645\u0646 \u0627\u0633\u062a\u0644\u0627\u0645 \u0625\u0634\u0639\u0627\u0631 \u0639\u0628\u0631 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0628\u0648\u0635\u0648\u0644 \u0627\u0644\u0645\u0631\u0643\u0628\u0629.<\/li>\n\n\n\n<li>\u0625\u0630\u0627 \u0643\u0646\u062a \u062a\u0633\u062a\u062e\u062f\u0645 \u062a\u0631\u062a\u064a\u0628 \u062a\u0645\u0648\u064a\u0644\u060c \u0641\u064a\u062c\u0628 \u0639\u0644\u064a\u0643 \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0644\u062c\u0645\u064a\u0639 \u0627\u0644\u0634\u0631\u0648\u0637 \u0627\u0644\u0645\u0633\u0628\u0642\u0629 \u0627\u0644\u0645\u0637\u0644\u0648\u0628\u0629 \u0642\u0628\u0644 \u0627\u0644\u0627\u0633\u062a\u0644\u0627\u0645 \u0643\u0645\u0627 \u0647\u0648 \u0645\u0648\u0636\u062d \u0641\u064a \u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0627\u0644\u062a\u0645\u0648\u064a\u0644.<\/li>\n<\/ol>\n\n\n\n<p><strong>4. <\/strong><strong>\u0643\u064a\u0641\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629<\/strong><strong><\/strong><\/p>\n\n\n\n<ol start=\"1\" class=\"wp-block-list\">\n<li>\u0646\u0642\u0648\u0645 \u0628\u062c\u0645\u0639 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0644\u062a\u0646\u0641\u064a\u0630 \u0647\u0630\u0627 \u0627\u0644\u0639\u0642\u062f\u060c \u0648\u0644\u0646 \u062a\u062a\u0645 \u0645\u0634
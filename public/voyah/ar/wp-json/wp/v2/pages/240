27\u062a\u060c \u0633\u062a\u0642\u0648\u0645 \u0628\u0645\u0639\u0627\u0644\u062c\u0629 \u0623\u064a \u0628\u064a\u0627\u0646\u0627\u062a \u0634\u062e\u0635\u064a\u0629 \u062a\u062f\u062e\u0644\u0647\u0627 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639 \u0648\u0641\u0642\u064b\u0627 \u0644\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0639\u0645\u0648\u0644 \u0628\u0647\u0627.<\/li>\n\n\n\n<li>\u0633\u064a\u062a\u0645 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0642\u062f\u0645\u0647\u0627 \u0644\u0640 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0644\u0644\u0623\u063a\u0631\u0627\u0636 \u0627\u0644\u062a\u0627\u0644\u064a\u0629: 2.1 \u0644\u0623\u063a\u0631\u0627\u0636 \u062a\u0639\u0627\u0642\u062f\u064a\u0629\u060c \u0644\u062a\u0646\u0641\u064a\u0630 \u0627\u062a\u0641\u0627\u0642\u064a\u0627\u062a \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a \u0623\u0648 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0623\u0648 \u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0636\u0645\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0635\u0646\u0639\u0629 \u0644\u0644\u0645\u0631\u0643\u0628\u0629 \u0641\u064a \u062d\u0627\u0644 \u0634\u0631\u0627\u0621\u0643 \u0644\u0645\u0631\u0643\u0628\u0629\u061b \u0648\/\u0623\u0648 2.2 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0645\u0648\u0627\u0641\u0642\u062a\u0643 \u0627\u0644\u0635\u0631\u064a\u062d\u0629\u060c \u0644\u062a\u0632\u0648\u064a\u062f\u0643 \u0628\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0639\u0646 \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a \u0648\/\u0623\u0648 \u0627\u0644\u0639\u0631\u0648\u0636 \u0627\u0644\u062a\u0631\u0648\u064a\u062c\u064a\u0629 \u0644\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0648\u0644\u0625\u062c\u0631\u0627\u0621 \u0628\u062d\u0648\u062b \u0627\u0644\u0633\u0648\u0642 \u0648\u0627\u0644\u0627\u0633\u062a\u0637\u0644\u0627\u0639\u0627\u062a.<\/li>\n\n\n\n<li>\u0633\u064a\u062a\u0645 \u0645\u0639\u0627\u0644\u062c\u0629 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0644\u0644\u0623\u063a\u0631\u0627\u0636 \u0627\u0644\u0645\u062d\u062f\u062f\u0629 \u0623\u0639\u0644\u0627\u0647 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0645\u0624\u062a\u0645\u062a\u0629 \u0648\u063a\u064a\u0631 \u0645\u0624\u062a\u0645\u062a\u0629\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0645\u0628\u0627\u062f\u0626 \u0627\u0644\u0633\u0631\u064a\u0629 \u0648\u0627\u0644\u062a\u062f\u0627\u0628\u064a\u0631 \u0627\u0644\u0623\u0645\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0642\u062a\u0636\u064a\u0647\u0627 \u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0639\u0645\u0648\u0644 \u0628\u0647\u0627.<\/li>\n\n\n\n<li>\u0623\u0646\u062a \u0647\u0646\u0627 \u062a\u0642\u0631 \u0648\u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649: 4.1 \u0623\u0646\u0643 \u062a\u0642\u062f\u0645 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0644\u062a\u062a\u0645 \u0645\u0639\u0627\u0644\u062c\u062a\u0647\u0627 \u0628\u0648\u0627\u0633\u0637\u0629 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0644\u0644\u0623\u063a\u0631\u0627\u0636 \u0627\u0644\u0645\u062d\u062f\u062f\u0629 \u0641\u064a \u0627\u0644\u0628\u0646\u062f 2.2 \u0623\u0639\u0644\u0627\u0647\u061b \u0648 4.2 \u0642\u062f \u062a\u0642\u0648\u0645 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0628\u0627\u0644\u0643\u0634\u0641 \u0639\u0646 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0625\u0630\u0627 \u0643\u0627\u0646\u062a \u0645\u0637\u0644\u0648\u0628\u0629 \u0644\u0644\u0642\u064a\u0627\u0645 \u0628\u0630\u0644\u0643: 4.2.1 \u0628\u0645\u0648\u062c\u0628 \u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0639\u0645\u0648\u0644 \u0628\u0647\u0627. 4.2.2 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0637\u0644\u0628 \u0623\u064a \u062c\u0647\u0629 \u062d\u0643\u0648\u0645\u064a\u0629. 4.2.3 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0637\u0644\u0628 \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0635\u0646\u0639\u0629 \u0644\u0644\u0645\u0631\u0643\u0628\u0629. 4.2.4 \u0641\u064a \u0627\u0644\u0627\u0639\u062a\u0642\u0627\u062f \u0627\u0644\u062d\u0633\u0646 \u0628\u0623\u0646 \u0647\u0630\u0647 \u0627\u0644\u062e\u0637\u0648\u0629 \u0636\u0631\u0648\u0631\u064a\u0629. 4.2.5 \u0644\u0644\u0627\u0645\u062a\u062b\u0627\u0644 \u0644\u0627\u0644\u062a\u0632\u0627\u0645 \u0642\u0627\u0646\u0648\u0646\u064a. 4.2.6 \u0644\u062d\u0645\u0627\u064a\u0629 \u0648\u0627\u0644\u062f\u0641\u0627\u0639 \u0639\u0646 \u062d\u0642\u0648\u0642 \u0623\u0648 \u0645\u0645\u062a\u0644\u0643\u0627\u062a VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629. 4.2.7 \u0644\u062d\u0645\u0627\u064a\u0629 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0636\u062f \u0627\u0644\u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629.<\/li>\n<\/ol>\n\n\n\n<p><\/p>\n\n\n\n<p><strong>\u0627\u0644\u0642\u0627\u0646\u0648\u0646 <\/strong><strong>\u0627\u0644\u0648\u0627\u062c\u0628 <\/strong><strong>\u0627\u0644\u062a\u0637\u0628\u064a\u0642 <\/strong><strong>\u0648\u062a\u0633\u0648\u064a\u0629 <\/strong><strong>\u0627\u0644\u0646\u0632\u0627\u0639\u0627\u062a<\/strong><\/p>\n\n\n\n<ol class=\"wp-block-list\">\n<li>VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0645\u0642\u0631\u0647\u0627 \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u0648\u0633\u0648\u0641 \u062a\u062e\u0636\u0639 \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0647\u0630\u0647 \u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.<\/li>\n\n\n\n<li>\u0641\u064a \u062d\u0627\u0644 \u062d\u062f\u0648\u062b \u0646\u0632\u0627\u0639 \u064a\u0646\u0634\u0623 \u0639\u0646 \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0647\u0630\u0647\u060c \u0641\u0625\u0646\u0643 \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0645\u0639 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0644\u062d\u0644 \u0647\u0630\u0627 \u0627\u0644\u0646\u0632\u0627\u0639 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a \u0628\u062d\u0633\u0646 \u0646\u064a\u0629. \u0648\u0625\u0630\u0627 \u0641\u0634\u0644\u062a \u0647\u0630\u0647 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a\u060c \u0641\u0625\u0646\u0643 \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0623\u0646 \u064a\u062a\u0645 \u062d\u0644 \u0627\u0644\u0646\u0632\u0627\u0639 \u0628\u0648\u0627\u0633\u0637\u0629 \u0623\u064a \u0645\u062d\u0643\u0645\u0629 \u0630\u0627\u062a \u0627\u062e\u062a\u0635\u0627\u0635 \u0642\u0636\u0627\u0626\u064a \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.<\/li>\n<\/ol>\n\n\n\n<p><strong>\u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0648\u0627\u0644\u0623\u0633\u0639\u0627\u0631<\/strong> \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0628\u0634\u0623\u0646 \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0627\u0644\u0645\u0639\u0631\u0648\u0636\u0629 \u0623\u0648 \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0642\u0639 \u0647\u064a \u0644\u0623\u063a\u0631\u0627\u0636 \u0625\u0631\u0634\u0627\u062f\u064a\u0629 \u0648\u0625\u0639\u0644\u0627\u0645\u064a\u0629 \u0641\u0642\u0637 \u0648\u0644\u0627 \u062a\u0639\u062a\u0628\u0631 \u062c\u0632\u0621\u064b\u0627 \u0645\u0646 \u0639\u0642\u062f. \u0642\u062f \u064a\u062a\u0645 \u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0641\u064a \u0623\u064a \u0648\u0642\u062a \u062f\u0648\u0646 \u0625\u0634\u0639\u0627\u0631 \u0645\u0633\u0628\u0642. \u0646\u0638\u0631\u064b\u0627 \u0644\u0637\u0628\u064a\u0639\u0629 \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0627 \u0648\u0627\u0644\u062f\u0642\u0629\u060c \u0642\u062f \u062a\u062e\u062a\u0644\u0641 \u0627\u0644\u0623\u0644\u0648\u0627\u0646 \u0627\u0644\u0645\u0639\u0631\u0648\u0636\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0642\u0639 \u0639\u0646 \u0627\u0644\u0623\u0644\u0648\u0627\u0646 \u0627\u0644\u0641\u0639\u0644\u064a\u0629 \u0644\u0644\u0645\u0646\u062a\u062c\u0627\u062a. \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u062a\u0623\u0643\u062f \u0628\u0646\u0641\u0633\u0643 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0632\u064a\u0627\u0631\u0629 \u0641\u0631\u0648\u0639\u0646\u0627 \u0623\u0648 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0628\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0645\u0648\u062d\u062f.<\/p>\n\n\n\n<p><strong>\u0627\u0644\u062a\u0639\u062f\u064a\u0644 \u0648\u0627\u0644\u062a\u063a\u064a\u064a\u0631<\/strong> \u064a\u062d\u062a\u0641\u0638 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0628\u0627\u0644\u062d\u0642 \u0641\u064a \u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645 \u0623\u0648 \u0625\u0632\u0627\u0644\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0628\u0634\u0643\u0644 \u0645\u0624\u0642\u062a \u0623\u0648 \u062f\u0627\u0626\u0645 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0642\u0639 \u0648\u0641\u0642\u064b\u0627 \u0644\u062a\u0642\u062f\u064a\u0631\u0647. \u0623\u064a \u062a\u063a\u064a\u064a\u0631 \u0623\u0648 \u062a\u0639\u062f\u064a\u0644 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645 \u0633\u064a\u0643\u0648\u0646 \u0633\u0627\u0631\u064a\u064b\u0627 \u0628\u0645\u062c\u0631\u062f \u0646\u0634\u0631\u0647 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0642\u0639 \u0623\u0648 \u0627\u0633\u062a\u0628\u062f\u0627\u0644 \u0623\u064a \u0634\u0631\u0648\u0637 \u0648\u0623\u062d\u0643\u0627\u0645 \u062a\u0645 \u0646\u0634\u0631\u0647\u0627 \u0645\u0633\u0628\u0642\u064b\u0627. \u0648\u0645\u0639 \u0630\u0644\u0643\u060c \u0644\u0646 \u062a\u0624\u062b\u0631 \u0647\u0630\u0647 \u0627\u0644\u062a\u0639\u062f\u064a\u0644\u0627\u062a \u0648\u0627\u0644\u062a\u063a\u064a\u064a\u0631\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u062a\u0631\u062a\u064a\u0628\u0627\u062a \u0627\u0644\u062a\u0639\u0627\u0642\u062f\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0645 \u062a\u0646\u0641\u064a\u0630\u0647\u0627 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639 \u0642\u0628\u0644 \u0633\u0631\u064a\u0627\u0646 \u0647\u0630\u0647 \u0627\u0644\u062a\u063a\u064a\u064a\u0631\u0627\u062a. \u064a\u0639\u062f \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u0643 \u0641\u064a \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639 \u0628\u0639\u062f \u0625\u062f\u062e\u0627\u0644 \u0627\u0644\u062a\u0639\u062f\u064a\u0644\u0627\u062a \u0645\u0648\u0627\u0641\u0642\u0629 \u0644\u0627 \u0631\u062c\u0639\u0629 \u0641\u064a\u0647\u0627 \u0645\u0646\u0643 \u0639\u0644\u0649 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645 \u0627\u0644\u0645\u0639\u062f\u0644\u0629 \u0623\u0648 \u0627\u0644\u0645\u062a\u063a\u064a\u0631\u0629.<\/p>\n\n\n\n<p><strong>\u0627\u0644\u062d\u0642\u0648\u0642 \u0627\u0644\u0645\u0644\u0643\u064a\u0629<\/strong> \u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0
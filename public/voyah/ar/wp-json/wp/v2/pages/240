\u0639. \u064a\u0645\u0643\u0646\u0643 \u0637\u0628\u0627\u0639\u0629 \u0623\u0648 \u062a\u0646\u0632\u064a\u0644 \u0646\u0633\u062e \u0645\u0646 \u0627\u0644\u0645\u0648\u0642\u0639 \u0644\u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0634\u062e\u0635\u064a.<\/p>\n\n\n\n<p><strong>\u0627\u0644\u062a\u0639\u0648\u064a\u0636<\/strong> \u0643\u0645\u062a\u0637\u0644\u0628 \u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639\u060c \u064a\u062c\u0628 \u0639\u0644\u064a\u0643 \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0629 \u0639\u0644\u0649 \u062a\u0639\u0648\u064a\u0636 VOYAH \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0639\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0648\u0627\u0644\u0623\u0636\u0631\u0627\u0631 \u0648\u0627\u0644\u0645\u0637\u0627\u0644\u0628\u0627\u062a \u0648\u0627\u0644\u0646\u0641\u0642\u0627\u062a (\u0628\u0645\u0627 \u0641\u064a \u0630\u0644\u0643 \u0631\u0633\u0648\u0645 \u0627\u0644\u0645\u062d\u0627\u0645\u0627\u0629) \u0627\u0644\u0646\u0627\u0634\u0626\u0629 \u0639\u0646 \u0627\u0646\u062a\u0647\u0627\u0643\u0643 \u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639. \u064a\u0634\u0645\u0644 \u0630\u0644\u0643\u060c \u0639\u0644\u0649 \u0633\u0628\u064a\u0644 \u0627\u0644\u0645\u062b\u0627\u0644 \u0644\u0627 \u0627\u0644\u062d\u0635\u0631\u060c \u0623\u064a \u0645\u0637\u0627\u0644\u0628\u0627\u062a \u062a\u0632\u0639\u0645 \u0627\u0646\u062a\u0647\u0627\u0643\u0643 \u0644\u0647\u0630\u0627 \u0627\u0644\u0627\u062a\u0641\u0627\u0642.<strong>\u0627\u0644\u0627\u062a\u0635\u0627\u0644\u0627\u062a \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629<\/strong> \u0642\u062f \u064a\u062a\u0636\u0645\u0646 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0642\u0639 \u0631\u0648\u0627\u0628\u0637 \u062e\u0627\u0631\u062c\u064a\u0629 \u0642\u062f \u062a\u0624\u062f\u064a \u0625\u064